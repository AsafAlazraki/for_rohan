      "subject":             { "source": "subject",                  "type": "text" },
      "description":         { "source": "description",              "type": "text" },
      "owningBusinessUnit":  { "source": "_owningbusinessunit_value","type": "lookup", "entitySet": "businessunits" },
      "crmLeadStatus":       { "source": "statuscode",               "type": "choice", "optionSet": "statuscode" },
