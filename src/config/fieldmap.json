      "address1_postalcode": { "source": "postalCode",               "type": "text" },
      "companyname":         { "source": "company",                  "type": "text" },
      "subject":             { "source": "subject",                  "type": "text" },
      "description":         { "source": "description",              "type": "text" }
    }
