      "industryClassification": { "source": "_ubt_industryclassification_value", "type": "lookup", "entitySet": "ubt_industryclassifications" },
      "website":             { "source": "websiteurl",               "type": "text" },
      "mainPhone":           { "source": "telephone1",               "type": "text" },
      "industry":            { "source": "industrycode",             "type": "choice", "optionSet": "industrycode" },
      "annualRevenue":       { "source": "revenue",                  "type": "text" },
