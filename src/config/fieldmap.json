    },
    "contact": {
      "firstName":           { "source": "firstname",                "type": "text" },
      "lastName":            { "source": "lastname",                 "type": "text" },
      "email":               { "source": "emailaddress1",            "type": "text" },
      "title":               { "source": "jobtitle",                 "type": "text" },
      "phone":               { "source": "telephone1",               "type": "text" },
      "mobilePhone":         { "source": "mobilephone",              "type": "text" },
