      "communityMember":     { "source": "ubt_communitymember",      "type": "choice", "optionSet": "ubt_communitymember" },
      "contactAccountType":  { "source": "@derived",                 "type": "derived", "derivation": "parentAccountType" },
      "unsubscribed":        { "source": "donotbulkemail",           "type": "boolean" },
      "crmEntityType":       { "source": "@literal",                 "type": "literal", "value": "contact" },
      "crmContactId":        { "source": "contactid",                "type": "guid" }
    },
    "lead": {
      "firstName":           { "source": "firstname",                "type": "text" },
      "lastName":            { "source": "lastname",                 "type": "text" },
      "email":               { "source": "emailaddress1",            "type": "text" },
      "title":               { "source": "jobtitle",                 "type": "text" },
      "phone":               { "source": "telephone1",               "type": "text" },
      "mobilePhone":         { "source": "mobilephone",              "type": "text" },
      "addressLine1":        { "source": "address1_line1",           "type": "text" },
      "city":                { "source": "address1_city",            "type": "text" },
      "postalCode":          { "source": "address1_postalcode",      "type": "text" },
      "country":             { "source": "_ubt_countryid_value",     "type": "lookup", "entitySet": "ubt_countries" },
