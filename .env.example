# ─── Dapr / Azure Service Bus pubsub ─────────────────────────────────────────
# Dapr pubsub component and topic names for Service Bus integration
DAPR_PUBSUB_NAME=pubsub
DAPR_TOPIC_DYNAMICS=dynamics-contacts
DAPR_TOPIC_MARKETO=marketo-events
# Allow unverified Dapr (dev only, never true in prod)
ALLOW_UNVERIFIED_DAPR=false
# Service Bus connection string (used by scripts/publish-test.js; do not commit real secrets)
SERVICE_BUS_CONNECTION_STRING=
# ═══════════════════════════════════════════════════════════════════════════════
# dynamics-marketo-sync — environment variable reference
#
# Copy this file to .env and fill in your values before starting the service.
#   cp .env.example .env
#
# Variables marked (required) must be present or the service will refuse to start.
# Variables marked (optional) have safe defaults.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production          # development | production | test
PORT=3000                    # HTTP port the service listens on (optional, default 3000)
LOG_LEVEL=info               # error | warn | info | debug  (optional, default info)

 

# Azure PostgreSQL connection string
DATABASE_URL=                 # (required) postgres://<user>:<password>@<host>:5432/<database>

# Path to the CA bundle used to verify the Postgres TLS chain. Required when
# connecting through a corporate proxy that intercepts TLS, or against a pooler
# endpoint whose chain isn't in the system CA store — without it you'll see
# "self-signed certificate in certificate chain". Download from:
 
# See README § "TLS setup" for details.
PG_CA_CERT=                   # e.g. /absolute/path/to/certs/prod-ca-2021.crt

# ─── Microsoft Dynamics CRM ───────────────────────────────────────────────────
# Azure AD app registration created for this integration.
# See docs/CREDENTIALS_SETUP.md § 1 for step-by-step instructions.
DYNAMICS_TENANT_ID=          # (required) Azure AD tenant ID (GUID)
DYNAMICS_CLIENT_ID=          # (required) App registration client ID (GUID)
DYNAMICS_CLIENT_SECRET=      # (required) App registration client secret

# The API endpoint of your Dynamics organisation.
# Format: https://<your-org>.api.crm.dynamics.com   (US/default region)
#         https://<your-org>.api.crm4.dynamics.com  (EMEA)
#         https://<your-org>.api.crm3.dynamics.com  (Canada)
DYNAMICS_ORG_URL=https://yourorg.api.crm.dynamics.com
# Alias used internally — set to the same value as DYNAMICS_ORG_URL
DYNAMICS_RESOURCE_URL=https://yourorg.api.crm.dynamics.com

DYNAMICS_API_VERSION=9.2     # Dataverse API version (optional, default 9.2)

# Shared secret used to validate HMAC-SHA256 signatures on incoming Dynamics webhooks.
# Must match the secret configured in the Plugin Registration Tool.
# Generate with: openssl rand -hex 32
DYNAMICS_WEBHOOK_SECRET=     # (required)

# ─── Marketo ──────────────────────────────────────────────────────────────────
# Marketo LaunchPoint API-only service created for this integration.
# See docs/CREDENTIALS_SETUP.md § 2 for step-by-step instructions.

# Your Marketo Munchkin ID (e.g. 123-ABC-456).
# The REST API base URL is derived from it: https://<munchkin-id>.mktorest.com
MARKETO_MUNCHKIN_ID=         # e.g. 123-ABC-456
MARKETO_BASE_URL=https://000-AAA-000.mktorest.com   # (required) full base URL

MARKETO_CLIENT_ID=           # (required) LaunchPoint service client ID
MARKETO_CLIENT_SECRET=       # (required) LaunchPoint service client secret

# Shared secret (token) used to validate incoming Marketo webhook calls.
# Must match the token set in the Marketo Smart Campaign webhook definition.
# Generate with: openssl rand -hex 32
MARKETO_WEBHOOK_TOKEN=       # (required) — also exposed as MARKETO_WEBHOOK_SECRET
MARKETO_WEBHOOK_SECRET=      # (required) same value as MARKETO_WEBHOOK_TOKEN

# ─── Sync engine tuning ───────────────────────────────────────────────────────


SYNC_QUEUE_NAME=sync-events   # pg-boss queue name (optional)
SYNC_CONCURRENCY=5            # Number of parallel job processors (optional, default 5)
SYNC_JOB_ATTEMPTS=3           # Max retry attempts before a job lands in the DLQ (optional, default 3)
DEDUP_WINDOW_SECONDS=30       # (future) in-flight dedup window (optional)

# ─── Alerting ─────────────────────────────────────────────────────────────────
# Slack incoming webhook or PagerDuty Events API v2 URL.
# Leave blank to disable alerts (service still runs normally).
SLACK_WEBHOOK_URL=            # e.g. https://hooks.slack.com/services/…  (optional)
ALERT_WEBHOOK_URL=            # alias for SLACK_WEBHOOK_URL

ALERT_DLQ_THRESHOLD=10        # Alert fires when DLQ depth exceeds this (optional, default 10)
ALERT_ERROR_RATE_THRESHOLD=0.05  # Alert fires when 15-min error rate exceeds 5 % (optional)
ALERT_HEARTBEAT_MS=60000      # How often to check metrics in ms (optional, default 60000)
